<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileKeeper.UI.ViewModels"
        xmlns:dtos="clr-namespace:FileKeeper.UI.Models;assembly=FileKeeper.UI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
        x:Class="FileKeeper.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}">

    <Window.Styles>
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#6B7280" />
        </Style>

        <Style Selector="ListBox.snapshot-list">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="ListBox.snapshot-list > ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#1D4ED8" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#60A5FA" />
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E40AF" />
        </Style>
    </Window.Styles>


    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="24,20">
        
        <!-- Error Message -->
        <Border Grid.Row="0"
                Background="#FFE74C3C"
                IsVisible="{Binding IsErrorVisible}"
                Padding="8"
                CornerRadius="4"
                Margin="0,0,0,8">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="White"
                       TextWrapping="Wrap" />
        </Border>
        
        <!-- Backup Progress -->
        <Border Grid.Row="1"
                Background="#F0F8FF"
                IsVisible="{Binding IsBackupInProgress}"
                Padding="8"
                Margin="0,0,0,8"
                BorderBrush="#87CEEB"
                BorderThickness="1"
                CornerRadius="4">
            <StackPanel Spacing="8">
                <ProgressBar Value="{Binding BackupProgress}" Maximum="100" Height="20" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#1E90FF"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        
        <!-- ...existing header border... -->
        <Border Grid.Row="2" Background="#F5F7FB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,16">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="page-title" Text="Snapshots" />
                <Border Grid.Row="0" Grid.Column="1" Background="#E8F0FF" CornerRadius="999" Padding="10,4" VerticalAlignment="Center">
                    <Grid>
                        <TextBlock Text="{Binding Snapshots.Count, StringFormat='Total: {0}'}"
                                   FontWeight="SemiBold"
                                   Foreground="#1D4ED8"
                                   IsVisible="{Binding !IsLoading}" />
                        <TextBlock Text="Loading..."
                                   FontWeight="SemiBold"
                                   Foreground="#1D4ED8"
                                   IsVisible="{Binding IsLoading}" />
                    </Grid>
                </Border>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Classes="muted" Margin="0,6,0,0"
                           Text="Recent backup snapshots with file count and stored size." />
            </Grid>
        </Border>

        <!-- ...existing list... -->
        <Grid Grid.Row="3" ColumnDefinitions="3*,4*" ColumnSpacing="16">
            <Grid Grid.Column="0">
                <ListBox Classes="snapshot-list"
                         ItemsSource="{Binding Snapshots}"
                         SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="dtos:SnapshotDto">
                            <Border Background="#FAFAFA" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="14,12">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Classes="muted"
                                                   Text="{Binding CreatedAtUtc, StringFormat='Created {0:yyyy-MM-dd HH:mm}'}" />
                                    </Grid>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                        <Border Background="#EEF2FF" CornerRadius="999" Padding="10,4">
                                            <TextBlock Text="{Binding FileCount, StringFormat='Files: {0}'}"
                                                       Foreground="#3730A3"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <Border Background="#ECFEF3" CornerRadius="999" Padding="10,4">
                                            <TextBlock Text="{Binding FormattedTotalSize, StringFormat='Size: {0:N0}'}"
                                                       Foreground="#166534"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Background="#AAFFFFFF"
                        CornerRadius="10"
                        IsVisible="{Binding IsLoading}">
                    <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Width="220" IsIndeterminate="True" />
                        <TextBlock Classes="muted" HorizontalAlignment="Center" Text="Loading snapshots..." />
                    </StackPanel>
                </Border>
            </Grid>

            <ContentControl Grid.Column="1" Content="{Binding SnapshotView}" />
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="4" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,10,0,0">
            <Button Classes="primary"
                    HorizontalAlignment="Right"
                    Command="{Binding CreateSnapshotCommand}"
                    CornerRadius="8"
                    Padding="16,10"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Width="16" Height="16"
                              Foreground="White"
                              Data="M20,5H16.83L15,3H9L7.17,5H4A2,2 0 0,0 2,7V19A2,2 0 0,0 4,21H20A2,2 0 0,0 22,19V7A2,2 0 0,0 20,5M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z" />
                    <TextBlock Text="Create new snapshot" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Border>
    </Grid>

</Window>
