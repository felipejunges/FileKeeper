<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FileKeeper.UI.ViewModels"
             x:Class="FileKeeper.UI.Views.SettingsView"
             x:Name="Root"
             x:DataType="vm:SettingsViewModel">

    <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="16">
        <Grid RowDefinitions="*,Auto" RowSpacing="12">
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                    <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" />
                    <!-- ...existing code... -->
                    <TextBlock Grid.Row="1"
                               Foreground="#6B7280"
                               Text="One source directory per line." />

                    <StackPanel Grid.Row="2" Spacing="6">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBlock Text="Source directories" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding AddSourceFolderCommand}"
                                    Background="#EEF2FF"
                                    Foreground="#1D4ED8"
                                    CornerRadius="6"
                                    Padding="10,6"
                                    Cursor="Hand">
                                <TextBlock Text="Add folder" FontWeight="SemiBold" />
                            </Button>
                        </Grid>

                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="6" MinHeight="120">
                            <ListBox ItemsSource="{Binding SourceDirectories}" BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,1">
                                            <TextBlock Text="{Binding .}" VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                            <Button Grid.Column="1"
                                                    Command="{ReflectionBinding #Root.DataContext.RemoveSourceDirectoryCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Background="#FEE2E2"
                                                    Foreground="#B91C1C"
                                                    CornerRadius="6"
                                                    Padding="6,2"
                                                    Cursor="Hand">
                                                <PathIcon Width="14" Height="14"
                                                          Data="M19,4H15.61L14.54,2.43C14.3,2.15 13.92,2 13.55,2H10.45C10.08,2 9.7,2.15 9.46,2.43L8.39,4H5A2,2 0 0,0 3,6V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V6C21,4.89 20.1,4 19,4M9,18H8V9H9V18M13,18H12V9H13V18M17,18H16V9H17V18Z" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Spacing="6">
                        <TextBlock Text="Ignored folders" FontWeight="SemiBold" />
                        <TextBlock Foreground="#6B7280" Text="Comma-separated list of folders to exclude." />
                        <TextBox Text="{Binding IgnoredFolders, Mode=TwoWay}"
                                 Watermark="e.g., /home/user/.cache, /tmp"
                                 AcceptsReturn="True"
                                 MinHeight="80"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Spacing="6">
                        <TextBlock Text="Storage directory" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox Text="{Binding StorageDirectory, Mode=TwoWay}"
                                     Watermark="/path/to/storage" />
                            <Button Grid.Column="1"
                                    Command="{Binding PickStorageFolderCommand}"
                                    Background="#EEF2FF"
                                    Foreground="#1D4ED8"
                                    CornerRadius="6"
                                    Padding="10,6"
                                    Cursor="Hand">
                                <TextBlock Text="Browse" FontWeight="SemiBold" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                <TextBlock Foreground="#166534"
                           Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !IsErrorVisible}" />
                <TextBlock Foreground="#B91C1C"
                           Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsErrorVisible}" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding ReloadSettingsCommand}"
                            Background="#FEF3C7"
                            Foreground="#92400E"
                            CornerRadius="8"
                            Padding="14,8"
                            Cursor="Hand">
                        <TextBlock Text="Undo" FontWeight="SemiBold" />
                    </Button>

                    <Button
                        Command="{Binding SaveSettingsCommand}"
                        Background="#1D4ED8"
                        Foreground="White"
                        CornerRadius="8"
                        Padding="14,8"
                        Cursor="Hand">
                        <TextBlock Text="Save settings" FontWeight="SemiBold" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>