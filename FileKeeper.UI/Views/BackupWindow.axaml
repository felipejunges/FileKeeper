<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileKeeper.UI.ViewModels"
        x:Class="FileKeeper.UI.Views.BackupWindow"
        x:DataType="vm:BackupWindowViewModel"
        Title="Backup Details"
        WindowStartupLocation="CenterScreen"
        Width="600" Height="400">

    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="10" Spacing="5">
            <TextBlock Text="Backup Details" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="{Binding Backup.CreatedAt, StringFormat='Date: {0:yyyy-MM-dd HH:mm:ss}'}" />
        </StackPanel>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Added">
                <ListBox ItemsSource="{Binding Backup.CreatedFiles}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="Edited">
                <ListBox ItemsSource="{Binding Backup.UpdatedFiles}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="Deleted">
                <ListBox ItemsSource="{Binding Backup.DeletedFiles}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
