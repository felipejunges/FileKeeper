<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileKeeper.UI.ViewModels"
        x:Class="FileKeeper.UI.Views.BackupWindow"
        x:DataType="vm:BackupWindowViewModel"
        Title="Backup Details"
        WindowStartupLocation="CenterScreen"
        Width="600" Height="400">

    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Margin="10" Spacing="5">
            <TextBlock Text="Backup Details" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="{Binding Backup.CreatedAt, StringFormat='Date: {0:yyyy-MM-dd HH:mm:ss}'}" />
        </StackPanel>

        <TabControl Grid.Row="1" Margin="10">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="MinHeight" Value="24" />
                </Style>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="8,4" />
                </Style>
            </TabControl.Styles>
            
            <TabItem Header="{Binding CreatedFilesTitle}">
                <ListBox ItemsSource="{Binding CreatedFiles}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="0,4">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding FullFileName}" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="15" Opacity="0.7">
                                        <TextBlock Text="{Binding FileSize, StringFormat='Size: {0:N0} bytes'}" FontSize="12" />
                                        <TextBlock Text="{Binding FileHash, StringFormat='Hash: {0}'}" FontSize="11" FontFamily="Courier New" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="{Binding UpdatedFilesTitle}">
                <ListBox ItemsSource="{Binding UpdatedFiles}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="0,4">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding FullFileName}" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="15" Opacity="0.7">
                                        <TextBlock Text="{Binding FileSize, StringFormat='Size: {0:N0} bytes'}" FontSize="12" />
                                        <TextBlock Text="{Binding FileHash, StringFormat='Hash: {0}'}" FontSize="11" FontFamily="Courier New" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="{Binding DeletedFilesTitle}">
                <ListBox ItemsSource="{Binding DeletedFiles}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="0,4">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding FullFileName}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
        
        <!-- Actions Footer -->
        <Border Grid.Row="2" Background="#F3F3F3" Padding="10" BorderThickness="0,1,0,0" BorderBrush="LightGray">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Command="{Binding RestoreBackupCommand}" Background="#E1F5FE">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="⬇️ Restore Backup" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding DeleteBackupCommand}" Background="#FFEBEE">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="🗑️ Delete Backup" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
