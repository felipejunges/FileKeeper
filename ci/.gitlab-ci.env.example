# Example CI variables for GitLab
# Add these in GitLab CI Settings -> CI/CD -> Variables

# Optional: token to allow creating PRs on GitHub (fork push & PR creation)
GITHUB_TOKEN=
# Required only if you want the PR step. Set to your GitHub username which owns the fork of flathub/apps
GITHUB_FORK_OWNER=
# Flathub app id, e.g. org.filekeeper.FileKeeper
FLATHUB_APP_ID=org.filekeeper.FileKeeper

# Optional: override default commit author used when creating the manifest commit
GIT_COMMITTER_NAME=CI Bot
GIT_COMMITTER_EMAIL=ci-bot@example.com

# Optional: DOTNET runtime id for building self-contained publish
DOTNET_RUNTIME_ID=linux-x64

